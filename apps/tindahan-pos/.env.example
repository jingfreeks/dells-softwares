# Copy this file to .env and fill in your Supabase project's values
# (Project Settings → API in the Supabase dashboard).
#
# VITE_SUPABASE_ANON_KEY is safe to expose in the browser bundle — it only
# grants what the Row Level Security policies in supabase/migrations allow
# for the signed-in user. NEVER put the service_role key in this file or
# anywhere in the frontend; it belongs only in the create-cashier Edge
# Function's environment (set via `supabase secrets set`).

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
